	return nil

}

func (s *FinanceiroService) CreateFatura(ctx context.Context, tenantID string, req *dto.CreateFaturaRequest) (*model.Fatura, error) {

	var dataPgto *time.Time

	if req.DataPagamentoBanco != nil && *req.DataPagamentoBanco != "" {

		t, err := time.Parse(time.RFC3339Nano, *req.DataPagamentoBanco)

		if err != nil {

			return nil, fmt.Errorf("data_pagamento_banco inválida %q: %w", *req.DataPagamentoBanco, err)

		}

		dataPgto = &t

	}

	var fatura *model.Fatura

	err := s.db.WithContext(ctx).Transaction(func(tx *gorm.DB) error {
		var existing model.Fatura
		if err := tx.Where("cartao_id = ? AND mes = ? AND ano = ? AND tenant_id = ?", req.CartaoID, req.Mes, req.Ano, tenantID).First(&existing).Error; err != nil {
			if !errors.Is(err, gorm.ErrRecordNotFound) {
				return err
			}
		}

		if existing.ID != "" {
			existing.Status = req.Status
			existing.ResponsavelID = req.ResponsavelID
			existing.DataPagamentoBanco = dataPgto
			if err := tx.Save(&existing).Error; err != nil {
				return err
			}
			fatura = &existing
		} else {
			fatura = &model.Fatura{
				ID:                 uuid.New().String(),
				TenantID:           tenantID,
				CartaoID:           req.CartaoID,
				Mes:                req.Mes,
				Ano:                req.Ano,
				ResponsavelID:      req.ResponsavelID,
				Status:             req.Status,
				DataPagamentoBanco: dataPgto,
			}
			if err := tx.Create(fatura).Error; err != nil {
				return err
			}
		}
		return nil
	})
	if err != nil {
		return nil, err
	}

	s.wsHub.Broadcast(tenantID, dto.WSMessage{

		Type: dto.WSTypeInvoiceUpdated,

		Payload: dto.FaturaToResponse(fatura),
	})

	return fatura, nil

}

func (s *FinanceiroService) CreateFaturaBatch(ctx context.Context, tenantID string, reqs []dto.CreateFaturaRequest) error {

	return s.db.WithContext(ctx).Transaction(func(tx *gorm.DB) error {

		for i := range reqs {

			req := &reqs[i]

			var dataPgto *time.Time

			if req.DataPagamentoBanco != nil && *req.DataPagamentoBanco != "" {

				t, err := time.Parse(time.RFC3339Nano, *req.DataPagamentoBanco)

				if err != nil {

					return fmt.Errorf("data_pagamento_banco inválida %q: %w", *req.DataPagamentoBanco, err)

				}

				dataPgto = &t

			}

			var fatura model.Fatura

			if err := tx.Where("cartao_id = ? AND mes = ? AND ano = ? AND tenant_id = ?", req.CartaoID, req.Mes, req.Ano, tenantID).First(&fatura).Error; err != nil && !errors.Is(err, gorm.ErrRecordNotFound) {
				return err
			}

			if fatura.ID != "" {

				fatura.Status = req.Status

				fatura.ResponsavelID = req.ResponsavelID

				fatura.DataPagamentoBanco = dataPgto

				if err := tx.Save(&fatura).Error; err != nil {

					return err

				}

			} else {

				fatura = model.Fatura{

					ID: uuid.New().String(),

					TenantID: tenantID,

					CartaoID: req.CartaoID,

					Mes: req.Mes,

					Ano: req.Ano,

					ResponsavelID: req.ResponsavelID,

					Status: req.Status,

					DataPagamentoBanco: dataPgto,
				}

				if err := tx.Create(&fatura).Error; err != nil {

					return err

				}

			}

		}

		return nil

	})

}

